<%- include('partials/header') %>

<main class="page-layout">

    <h1><%= title %></h1>

    <p class="page-intro">
        Explore upcoming opportunities to serve and strengthen your community.
    </p>

    <section class="card-grid">

    <% projects.forEach(project => { %>

        <div class="project-wrapper">

            <a href="/project/<%= project.project_id %>" class="card project-card">

                <strong>Date: <%= project.date.toLocaleDateString() %></strong>

                <br>

                <span><%= project.title %></span>

            </a>

            <div class="card-meta">
                <i>
                    <a href="/organization/<%= project.organization_id %>">
                        <%= project.organization_name %>
                    </a>
                </i>
            </div>

        </div>

    <% }); %>

</section>
<p><a href="/new-project">Add a new project</a></p>

</main>

<%- include('partials/footer') %>